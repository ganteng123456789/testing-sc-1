local function autoLoop()
    while running do
        doRoll()
        wait(0.2)
        doFarm()
        wait(0.3)
        doRebirth()
        wait(0.4)
        doPet()
        wait(0.2)
        doClick()
        wait(0.1)
        doCollect()
        wait(0.2)
        doHatch()
        wait(0.3)
        doQuest()
        wait(0.4)
        wait(0.1)
    end
end

btn.MouseButton1Click:Connect(function()
    if running then
        running = false
        btn.Text = "Start"
        btn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        status.Text = "Status: Stop"
    else
        running = true
        btn.Text = "Stop"
        btn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        status.Text = "Status: Running"
        
        -- Jalankan loop tanpa spawn (langsung)
        pcall(function()
            autoLoop()
        end)
    end
end)
