--[[
    Slime RNG | Free Auto (Universal)
    Menggunakan spawn() dan wait() untuk kompatibilitas
]]

local config = {
    auto_roll = true,
    auto_farm = true,
    auto_rebirth = true,
    auto_pet = true,
    auto_click = true,
    auto_collect = true,
    auto_hatch = true,
    auto_quest = true,
    settings = {
        delay_min = 0.1,
        delay_max = 0.5,
        debug = true
    }
}

local function log(msg)
    if config.settings.debug then
        print("[SlimeRNG] " .. tostring(msg))
    end
end

local function waitRandom(min, max)
    local delay = math.random() * (max - min) + min
    wait(delay)  -- <-- pakai wait() biasa
end

local function findObject(path)
    local parts = {}
    for part in string.gmatch(path, "[^%.]+") do
        table.insert(parts, part)
    end
    local current = game
    for _, part in ipairs(parts) do
        if current then
            current = current:FindFirstChild(part)
            if not current then
                return nil
            end
        else
            return nil
        end
    end
    return current
end

local function isGameValid()
    local players = game:GetService("Players")
    local localPlayer = players.LocalPlayer
    if not localPlayer then
        return false
    end
    return true
end

-- Variabel global untuk kontrol
isRunning = false
autoTasks = {}

