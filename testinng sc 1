local function mainLoop()
    local function roll()
        local btn = findObject("Players.LocalPlayer.PlayerGui.RollButton")
        if btn then btn:FireServer(); waitRandom(0.1, 0.3); return true end
        return false
    end

    local function farm()
        local btn = findObject("Players.LocalPlayer.PlayerGui.FarmButton")
        if btn then btn:FireServer(); waitRandom(0.2, 0.5); return true end
        return false
    end

    local function rebirth()
        local btn = findObject("Players.LocalPlayer.PlayerGui.RebirthButton")
        if btn then btn:FireServer(); waitRandom(0.3, 0.7); return true end
        return false
    end

    local function pet()
        local btn = findObject("Players.LocalPlayer.PlayerGui.PetButton")
        if btn then btn:FireServer(); waitRandom(0.1, 0.3); return true end
        return false
    end

    local function click()
        local btn = findObject("Players.LocalPlayer.PlayerGui.ClickButton")
        if btn then btn:FireServer(); waitRandom(0.05, 0.15); return true end
        return false
    end

    local function collect()
        local btn = findObject("Players.LocalPlayer.PlayerGui.CollectButton")
        if btn then btn:FireServer(); waitRandom(0.1, 0.2); return true end
        return false
    end

    local function hatch()
        local btn = findObject("Players.LocalPlayer.PlayerGui.HatchButton")
        if btn then btn:FireServer(); waitRandom(0.2, 0.4); return true end
        return false
    end

    local function quest()
        local btn = findObject("Players.LocalPlayer.PlayerGui.QuestButton")
        if btn then btn:FireServer(); waitRandom(0.3, 0.6); return true end
        return false
    end

    task.spawn(function()
        while isRunning and isGameValid() do
            if config.auto_roll then roll() end
            if config.auto_farm then farm() end
            if config.auto_rebirth then rebirth() end
            if config.auto_pet then pet() end
            if config.auto_click then click() end
            if config.auto_collect then collect() end
            if config.auto_hatch then hatch() end
            if config.auto_quest then quest() end
            waitRandom(config.settings.delay_min, config.settings.delay_max)
        end
    end)
end

local function init()
    if not isGameValid() then
        log("Tidak dalam game!")
        return
    end

    log("Slime RNG Free Auto dimulai...")
    createGUI()
end

local success, err = pcall(init)
if not success then
    warn("Error: " .. tostring(err))
end

game:GetService("Players").LocalPlayer.OnTeleport:Connect(function()
    local gui = game.CoreGui:FindFirstChild("SlimeRNG_Free")
    if gui then gui:Destroy() end
    isRunning = false
    for _, task in ipairs(autoTasks) do
        task:Disconnect()
    end
    autoTasks = {}
end)
