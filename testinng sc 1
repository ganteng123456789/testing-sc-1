-- SPECIAL TAB + Scheduler (Odd hour: 15 menit collect lalu train)
-- =========================================
local SpecialTab = CreateTab("Special")

local schedulerActive = false
local lastMode = nil -- "collect" / "train"

local function setMode(mode, currentHour, currentMin)
	if lastMode == mode then return end
	lastMode = mode

	local autoTrainCtl = UIControllers["AutoTrain"]
	local collectCtl   = UIControllers["AutoCollectVolcanoKamikaze"]

	if not autoTrainCtl then
		warn("Scheduler: UIControllers['AutoTrain'] belum ada (toggle AutoTrain belum dibuat / beda key)")
	end
	if not collectCtl then
		warn("Scheduler: UIControllers['AutoCollectVolcanoKamikaze'] belum ada (toggle collect belum dibuat / beda key)")
	end

	if mode == "collect" then
		print(("⚽ WIB %02d:%02d | Collect ON (AutoTrain OFF)"):format(currentHour, currentMin))
		if autoTrainCtl then autoTrainCtl(false) end
		task.wait(0.2)
		if collectCtl then collectCtl(true) end
	else
		print(("🏋️ WIB %02d:%02d | AutoTrain ON (Collect OFF)"):format(currentHour, currentMin))
		if collectCtl then collectCtl(false) end
		task.wait(0.2)
		if autoTrainCtl then autoTrainCtl(true) end
	end
end

CreateToggle(SpecialTab, "Enable Scheduler WIB ⏰", "EnableScheduler", function(v)
	schedulerActive = v

	if schedulerActive then
		task.spawn(function()
			while schedulerActive do
				-- WIB dari UTC
				local hourWIB = (tonumber(os.date("!%H")) + 7) % 24
				local minWIB  = tonumber(os.date("!%M"))

				local isOddHour = (hourWIB % 2 ~= 0)
				local inFirst15 = (minWIB < 16)

				if isOddHour and inFirst15 then
					setMode("collect", hourWIB, minWIB) -- 01:00-01:14, 03:00-03:14, dst
				else
					setMode("train", hourWIB, minWIB) -- sisanya
				end

				task.wait(5) -- cek tiap 5 detik biar responsif pas menit ganti
			end
		end)
	else
		-- reset semua saat OFF
		lastMode = nil
		if UIControllers["AutoTrain"] then UIControllers["AutoTrain"](false) end
		if UIControllers["AutoCollectVolcanoKamikaze"] then UIControllers["AutoCollectVolcanoKamikaze"](false) end
		print("Scheduler OFF")
	end
end)

