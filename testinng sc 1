    infoLabel.Position = UDim2.new(0.05, 0, 0.92, 0)
    infoLabel.Text = "✨ Gratis • Tanpa Key • Tanpa Iklan"
    infoLabel.TextColor3 = Color3.fromRGB(80, 80, 120)
    infoLabel.TextSize = 11
    infoLabel.BackgroundTransparency = 1
    infoLabel.Font = Enum.Font.Gotham
    infoLabel.Parent = frame

    local function updateStatus(text)
        statusLabel.Text = "Status: " .. text
    end

    -- Fungsi utama yang akan dijalankan di dalam spawn
    local function mainLoop()
        log("Main loop dimulai!")
        
        while isRunning and isGameValid() do
            -- Roll
            if config.auto_roll then
                local btn = findObject("Players.LocalPlayer.PlayerGui.RollButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.1, 0.3)
            end
            
            -- Farm
            if config.auto_farm then
                local btn = findObject("Players.LocalPlayer.PlayerGui.FarmButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.2, 0.5)
            end
            
            -- Rebirth
            if config.auto_rebirth then
                local btn = findObject("Players.LocalPlayer.PlayerGui.RebirthButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.3, 0.7)
            end
            
            -- Pet
            if config.auto_pet then
                local btn = findObject("Players.LocalPlayer.PlayerGui.PetButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.1, 0.3)
            end
            
            -- Click
            if config.auto_click then
                local btn = findObject("Players.LocalPlayer.PlayerGui.ClickButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.05, 0.15)
            end
            
            -- Collect
            if config.auto_collect then
                local btn = findObject("Players.LocalPlayer.PlayerGui.CollectButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.1, 0.2)
            end
            
            -- Hatch
            if config.auto_hatch then
                local btn = findObject("Players.LocalPlayer.PlayerGui.HatchButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.2, 0.4)
            end
            
            -- Quest
            if config.auto_quest then
                local btn = findObject("Players.LocalPlayer.PlayerGui.QuestButton")
                if btn then
                    pcall(function() btn:FireServer() end)
                end
                waitRandom(0.3, 0.6)
            end
            
            waitRandom(config.settings.delay_min, config.settings.delay_max)
        end
        
        log("Main loop berhenti.")
    end

    -- Event tombol Start/Stop
    startBtn.MouseButton1Click:Connect(function()
        if isRunning then
            log("Menghentikan...")
            isRunning = false
            startBtn.Text = "▶ Start"
            startBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
            updateStatus("Berhenti")
        else
            log("Memulai...")
            isRunning = true
            startBtn.Text = "■ Stop"
            startBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
            updateStatus("Berjalan...")
            -- Jalankan di spawn agar tidak memblokir
            spawn(function()
                mainLoop()
            end)
        end
    end)

    return screenGui, frame
end

-- Inisialisasi
local function init()
    if not isGameValid() then
        log("Tidak dalam game!")
        return
    end
    log("Inisialisasi...")
    createGUI()
    log("Siap!")
end

pcall(init)
