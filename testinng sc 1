    local x1 = Instance.new("Frame")
    x1.Size = UDim2.new(0,12,0,2)
    x1.AnchorPoint = Vector2.new(0.5,0.5)
    x1.Position = UDim2.new(0.5,0,0.5,0)
    x1.BackgroundColor3 = Theme.Text
