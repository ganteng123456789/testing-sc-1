local function Tween(obj, props, dur) 
    if not obj then return end
    TweenService:Create(obj, TweenInfo.new(dur or 0.25), props):Play() 
end
local function Corner(p,r) 
    local c = Instance.new("UICorner") 
    c.CornerRadius = r or Theme.CornerRadius 
    c.Parent = p 
    return c 
end

local StateStore = {}
function FreeUI:GetValue(n) return StateStore[n] end
function FreeUI:SetValue(n,v) StateStore[n]=v end

local ThreadManager = {}
local _activeThreads = {}
function ThreadManager:Start(key, interval, cb)
    self:Stop(key)
    _activeThreads[key] = task.spawn(function()
        while _activeThreads[key] do
            pcall(cb)
            task.wait(interval or 1)
        end
    end)
end
function ThreadManager:Stop(key) 
    if _activeThreads[key] then task.cancel(_activeThreads[key]); _activeThreads[key]=nil end
end
function ThreadManager:StopAll() 
    for k in pairs(_activeThreads) do self:Stop(k) end
end
FreeUI.ThreadManager = ThreadManager

local function CreateWindow(title)
    for _,v in pairs(playerGui:GetChildren()) do 
        if v.Name=="FreeUI_Window" then v:Destroy() end 
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "FreeUI_Window"
